{
  "manifest_version": 3,
  "name": "PagePulse — Why Is This Page Slow?",
  "version": "1.0.0",
  "description": "A computer networks diagnostic tool that analyzes why pages load slowly.",
  "permissions": ["tabs", "webNavigation", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/icon.png"
  }
}
